<%
  // Inputs: label, value, sublabel, pct (0..100)
  const r = 56;                         // ring radius
  const c = 2 * Math.PI * r;            // circumference
  const p = Math.max(0, Math.min(100, Number(pct) || 0));
  const dash = (p * c) / 100;
%>
<div class="bg-white rounded-lg shadow p-4 border flex flex-col items-center">
  <div class="relative" style="width:140px;height:140px">
    <svg viewBox="0 0 140 140" class="block">
      <circle cx="70" cy="70" r="<%= r %>" fill="none" stroke="#e5e7eb" stroke-width="12" />
      <circle
        cx="70" cy="70" r="<%= r %>" fill="none"
        stroke="currentColor" stroke-width="12" stroke-linecap="round"
        stroke-dasharray="<%= dash %> <%= c %>"
        transform="rotate(-90 70 70)"
        class="brand"
      />
    </svg>
    <div class="absolute inset-0 flex items-center justify-center">
      <div class="text-center">
        <div class="text-3xl font-bold"><%= value %></div>
        <div class="text-xs text-gray-500"><%= p %>%</div>
      </div>
    </div>
  </div>
  <div class="mt-3 text-sm font-medium text-center"><%= label %></div>
  <div class="text-xs text-gray-500"><%= sublabel %></div>
</div>

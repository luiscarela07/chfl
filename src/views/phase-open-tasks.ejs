<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="max-w-6xl mx-auto px-4 py-6">
  <div class="flex items-center justify-between mb-4">
    <h1 class="text-2xl font-semibold"><%= label %></h1>
    <a class="underline text-sm" href="/">Back to Dashboard</a>
  </div>

  <% if (!rows || !rows.length) { %>
    <div class="p-4 border rounded">No open tasks found for this phase.</div>
  <% } else { %>
    <div class="space-y-4">
      <% rows.forEach(r => { %>
        <div class="border rounded p-4">
          <div class="flex items-center justify-between">
            <div>
              <div class="font-semibold"><%= [r.firstName, r.lastName].filter(Boolean).join(' ') || r.clientName %></div>
              <div class="text-sm text-gray-600">Case #<%= r.caseId %></div>
            </div>
            <a class="underline text-sm" href="/cases/<%= r.caseId %>">Open Case</a>
          </div>

          <div class="mt-3 space-y-2">
            <% (r.openTasks || []).forEach(t => { %>
              <div class="pl-2">
                <div class="font-medium">
                  <span class="inline-block w-2 h-2 rounded-full mr-2 align-middle" style="background:<%= t.done ? '#10b981' : '#ef4444' %>"></span>
                  <%= t.title %>
                </div>

                <% if (t.subtasks && t.subtasks.length) { %>
                  <ul class="mt-1 ml-6 list-disc space-y-1">
                    <% t.subtasks.forEach(st => { %>
                      <li>
                        <span><%= st.title %></span>
                        <% if (st.grandchildren && st.grandchildren.length) { %>
                          <ul class="mt-1 ml-6 list-[circle] space-y-1">
                            <% st.grandchildren.forEach(gc => { %>
                              <li><%= gc.title %></li>
                            <% }) %>
                          </ul>
                        <% } %>
                      </li>
                    <% }) %>
                  </ul>
                <% } %>
              </div>
            <% }) %>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('partials/foot') %>

<%- include('partials/head') %>
<%- include('partials/nav') %>

<h1 class="text-2xl font-semibold mb-4"><%= item ? 'Edit Case' : 'New Case' %></h1>

<%
  const CASE_TYPES = ['MVA','Dog Bite','Work Injury','Premises','Trucking'];
  const it = item || {};
%>

<form method="post" class="bg-white rounded-lg shadow border p-4 space-y-3">
  <div>
    <label class="block text-sm text-gray-600 mb-1">Client Name</label>
    <input name="client_name" class="border rounded px-3 py-2 w-full" required value="<%= it.clientName || '' %>">
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
    <div>
      <label class="block text-sm text-gray-600 mb-1">Date of Incident</label>
      <input type="date" name="date_of_incident" class="border rounded px-3 py-2 w-full" required
             value="<%= it.dateOfIncident ? String(it.dateOfIncident).slice(0,10) : '' %>">
    </div>
    <div>
      <label class="block text-sm text-gray-600 mb-1">Type of Case</label>
      <select name="type_of_case" class="border rounded px-3 py-2 w-full" required>
        <option value="">Select</option>
        <% CASE_TYPES.forEach(t => { %>
          <option value="<%= t %>" <%= it.typeOfCase===t ? 'selected' : '' %>><%= t %></option>
        <% }) %>
      </select>
    </div>
    <div>
      <label class="block text-sm text-gray-600 mb-1">Phase</label>
      <select name="phase" class="border rounded px-3 py-2 w-full">
        <% for (let p=1;p<=4;p++){ %>
          <option value="<%= p %>" <%= it && it.phase===p ? 'selected' : '' %>>Phase <%= p %></option>
        <% } %>
      </select>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
    <div>
      <label class="block text-sm text-gray-600 mb-1">Due Date</label>
      <input type="date" name="due_date" class="border rounded px-3 py-2 w-full"
             value="<%= it && it.dueDate ? new Date(it.dueDate).toISOString().slice(0,10) : '' %>">
    </div>
    <div>
      <label class="block text-sm text-gray-600 mb-1">Status (stored only)</label>
      <select name="status" class="border rounded px-3 py-2 w-full">
        <option value="Open"  <%= it && it.status==='Open'  ? 'selected' : '' %>>Open</option>
        <option value="Closed"<%= it && it.status==='Closed'? 'selected' : '' %>>Closed</option>
      </select>
    </div>
    <div>
      <label class="block text-sm text-gray-600 mb-1">Litigation</label>
      <select name="litigation_status" class="border rounded px-3 py-2 w-full">
        <option value="pre" <%= (it.litigationStatus||'pre')==='pre'?'selected':'' %>>Pre</option>
        <option value="litigation" <%= (it.litigationStatus||'pre')==='litigation'?'selected':'' %>>Litigation</option>
      </select>
    </div>
  </div>

  <%- include('partials/phase2-dropdown') %>

  <div>
    <label class="block text-sm text-gray-600 mb-1">Description</label>
    <textarea name="description" class="border rounded px-3 py-2 w-full" rows="3"><%= it.description || '' %></textarea>
  </div>

  <div class="flex items-center gap-2">
    <button class="brand-bg text-white px-4 py-2 rounded"><%= item ? 'Save' : 'Create' %></button>
    <a href="<%= item ? `/cases/${item.id}` : '/cases' %>" class="px-4 py-2 border rounded">Cancel</a>
  </div>
</form>

<%- include('partials/foot') %>